HOST=0.0.0.0
PORT=5000
DEBUG=TRUE
# Local Docker Postgres (default).
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/twofit
# Supabase: the "direct" host (db.xxx.supabase.co) is often IPv6-only. Docker/IPv4 cannot reach it. Use
# Dashboard -> Connect -> Session pooler (or Transaction for serverless) and copy that URI; add ?sslmode=require
REDIS_URL=redis://redis:6379/0
SECRET_KEY=replace-me
JWT_SECRET_KEY=replace-me
OPENAI_API_KEY=
OPENAI_MODEL=
INTERNAL_OPENAI_MODEL=
AZURE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=
AZURE_PROFILE_CONTAINER_NAME=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
TWILIO_VERIFICATION_URL=
TWILIO_ENCRYPTED_USER=
TWILIO_ENCRYPTED_PASSWORD=
TWILIO_SERVICE_SID=
CORS_ORIGINS=http://localhost:3000
# Split deploy (Vercel + Render): set CORS_ORIGINS to your site origin(s), e.g. https://your-app.vercel.app
# DATABASE_URL: use Supabase connection string (often add sslmode=require). REDIS_URL is set by Render Key Value when using render.yaml.
GOOGLE_CLIENT_ID=
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
